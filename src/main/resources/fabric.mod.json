{
    "schemaVersion": 1,
    "id": "firmmod",
    "version": "${version}",
    "name": "Firmod",
    "description": "Firmod powered by NEU",
    "authors": [
        {
            "name": "Linnea Gräf",
            "contact": {
                "email": "nea@nea.moe"
            }
        }
    ],
    "contact": {
        "discord": "https://discord.gg/64pFP94AWA",
        "sources": "https://github.com/nea89o/Firmod",
		"modrinth": "https://modrinth.com/mod/firmod"
    },
    "license": "GPL 3.0 or Later",
    "accessWidener": "firmod.accesswidener",
    "icon": "assets/firmod/logo.png",
    "environment": "client",
    "entrypoints": {
        "main": [
            "moe.nea.firmod.Firmod::onInitialize"
        ],
        "mm_shedaniel:early_risers": [
            "moe.nea.firmod.init.EarlyRiser"
        ],
        "client": [
            "moe.nea.firmod.Firmod::onClientInitialize",
			"moe.nea.jarvis.fabric.JarvisMain"
        ],
        "rei_client": [
            "moe.nea.firmod.compat.rei.FirmodReiPlugin"
        ],
		"rei_common": [
			"moe.nea.firmod.compat.rei.FirmodReiCommonPlugin"
		],
        "modmenu": [
            "moe.nea.firmod.compat.modmenu.FirmodModMenuPlugin"
        ],
		"jade": [
			"moe.nea.firmod.compat.jade.FirmodJadePlugin"
		],
        "jarvis": [
            "moe.nea.firmod.jarvis.JarvisIntegration"
        ]
    },
    "mixins": [
        "firmod.mixins.json"
    ],
    "depends": {
        "fabric-api": ">=${fabric_api_version}",
        "fabric-language-kotlin": ">=${fabric_kotlin_version}",
        "minecraft": ">=${minecraft_version}"
    },
    "custom": {
        "modmenu": {
            "links": {
                "modmenu.discord": "https://discord.gg/64pFP94AWA"
            }
        },
        "mc-publish": {
            "dependencies": [
                "roughlyenoughitems(recommended){modrinth:rei}"
            ]
        }
    }
}
